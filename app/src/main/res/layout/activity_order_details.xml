<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".OrderDetailsActivity"
    android:orientation="vertical"
    android:background="#ddd5d5">

    <TextView
        android:id="@+id/productTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        android:text="Product Details"
        android:layout_marginRight="@dimen/cardview_compat_inset_shadow"
        android:layout_gravity="center"/>

    <LinearLayout
        android:id="@+id/layoutMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_details_order"
        android:orientation="vertical"
        android:paddingBottom="15dp"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="24dp"
        app:layout_editor_absoluteX="24dp">

        <ImageView
            android:id="@+id/orderProductImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/image_icon"
            android:layout_gravity="center"
            android:layout_marginTop="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Name: "
                android:textColor="#5c5b5b"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/orderedProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:textColor="#5c5b5b"
                android:textSize="14sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="15dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Price: "
                android:textColor="#5c5b5b"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/orderedProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:textColor="#5c5b5b"
                android:textSize="14sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="15dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="Size: "
                android:textColor="#5c5b5b"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/orderedProductSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:textColor="#5c5b5b"
                android:textSize="14sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="15dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:text="For: "
                android:textColor="#5c5b5b"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/orderedProductGender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:textColor="#5c5b5b"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="15dp"
        android:layout_marginHorizontal="24dp"
        android:weightSum="4"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/orderProductCancelButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:paddingBottom="5dp"
            android:text="X"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:background="@drawable/button_cancel"
            android:layout_marginRight="15dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/orderProductBuyButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingBottom="5dp"
            android:text="BUY"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:background="@drawable/button_yes"/>

    </LinearLayout>

</LinearLayout>