<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:id="@+id/imageLayout"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:orientation="vertical"
        android:background="@drawable/background_image_details">

        <ImageView
            android:id="@+id/productImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="15dp"
            android:padding="5dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/productCompanyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="25dp"
        android:layout_marginTop="10dp"
        android:textSize="12sp"
        android:textColor="#000000"
        android:text="Nike"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

    <TextView
        android:id="@+id/productName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="25dp"
        android:layout_marginTop="10dp"
        android:textSize="28sp"
        android:textColor="#6a7272"
        android:text="Nike"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/productPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="245dp"
        android:layout_marginTop="10dp"
        android:textSize="25sp"
        android:textColor="#ea1414"
        android:text="1000"
        android:textStyle="bold"/>

    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="25dp"
        app:tabIndicatorColor="@color/black"
        app:tabRippleColor="#e5e5e5"
        app:tabSelectedTextColor="#4a7262"
        app:tabTextColor="#989698"
        android:layout_marginTop="10dp">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_tab"
            android:text="6"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_tab"
            android:text="7"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_tab"
            android:text="8"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_tab"
            android:text="9"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_tab"
            android:text="10"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_tab"
            android:text="11"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_tab"
            android:text="12"/>

    </com.google.android.material.tabs.TabLayout>

    <TextView
        android:id="@+id/productDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="15dp"
        android:textColor="#Bc7474"
        android:textSize="12sp"/>

    <EditText
        android:id="@+id/textSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="15dp"
        android:textColor="#Bc7474"
        android:text="6"
        android:visibility="gone"
        android:textSize="12sp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/productAddToCartButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Add to Cart"
        android:textSize="17sp"
        android:textAllCaps="false"
        app:cornerRadius="10dp"
        android:backgroundTint="#0F85E2"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="330dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/productBuyNowButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Buy Now"
        android:textSize="17sp"
        android:textAllCaps="false"
        app:cornerRadius="10dp"
        android:layout_marginHorizontal="20dp"/>



</LinearLayout>